#!/bin/sh

FIRMAE_BOOT=true
FIRMAE_NET=true
FIRMAE_NVRAM=true
FIRMAE_KERNEL=true
FIRMAE_ETC=true
FIRMAE_LLM=true   # 全局LLM开关

# LLM pipeline configs (used by scripts/makeImage.sh)
LLM_PROVIDER=VAPI # mock关闭
LLM_MODEL=gpt-4.1
LLM_BASE_URL=https://api.v3.cm/v1
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=1600
LLM_CONF_THRESHOLD=0.6
LLM_VALIDATE_STRICT=false

if (${FIRMAE_ETC}); then
  TIMEOUT=240
  CHECK_TIMEOUT=360
else
  TIMEOUT=60
  CHECK_TIMEOUT=60
fi

if [ -n "${FIRMAE_DOCKER-}" ]; then
    FIRMAE_DIR=/work/FirmAE
    PSQL_IP=172.17.0.1
else
    FIRMAE_DIR=$(pwd)
    PSQL_IP=127.0.0.1
fi

BINARIES=( "busybox" "console" "gdb" "gdbserver" "strace" "libnvram.so" "libnvram_ioctl.so" )

# specify full paths to other directories
BINARY_DIR=${FIRMAE_DIR}/binaries/
TARBALL_DIR=${FIRMAE_DIR}/images/
SCRATCH_DIR=${FIRMAE_DIR}/scratch
SCRIPT_DIR=${FIRMAE_DIR}/scripts/

# functions to safely compute other paths

check_arch () {
    ARCHS=("armel" "mipseb" "mipsel")

    if [ -z "${1}" ]; then
        return 0
    fi

    match=0
    for i in "${ARCHS[@]}"; do
        if [ "${1}" == "$i" ]; then
            match=1
        fi
    done

    if [ "${match}" -eq 0 ]; then
        return 0
    fi

    return 1
}

check_number () {
    if [ "${1}" -ge 0 ]; then
        return 1
    fi

    return 0
}

check_root () {
    if [ "${EUID}" -eq 0 ]; then
        return 1
    fi

    return 0
}

get_fs () {
    if check_number "${1}"; then
        echo "Error: Invalid image number!"
        exit 1
    fi

    echo "`get_scratch "${1}"`/image.raw"
}

get_fs_mount () {
    if check_number "${1}"; then
        echo "Error: Invalid image number!"
        exit 1
    fi

    echo "`get_scratch "${1}"`/image/"
}

get_kernel () {
    if check_arch "${1}"; then
        echo "Error: Invalid architecture!"
        exit 1
    fi

    case "${1}" in
        armel)
            echo "${BINARY_DIR}/zImage.${1}"
            ;;
        mipseb)
            if (${FIRMAE_KERNEL}); then
              echo "${BINARY_DIR}/vmlinux.${1}.4"
            else
              echo "${BINARY_DIR}/vmlinux.${1}.2"
            fi
            ;;
        mipsel)
            if (${FIRMAE_KERNEL}); then
              echo "${BINARY_DIR}/vmlinux.${1}.4"
            else
              echo "${BINARY_DIR}/vmlinux.${1}.2"
            fi
            ;;
        *)
            echo "Error: Invalid architecture!"
            exit 1
    esac
}

get_boot_kernel () {
    if check_arch "${1}"; then
        echo "Error: Invalid architecture!"
        exit 1
    fi

    case "${1}" in
        armel)
            echo "${BINARY_DIR}/vmlinux.${1}"
            ;;
        mipseb)
            if (${FIRMAE_KERNEL}); then
              echo "${BINARY_DIR}/vmlinux.${1}.4"
            else
              echo "${BINARY_DIR}/vmlinux.${1}.2"
            fi
            ;;
        mipsel)
            if (${FIRMAE_KERNEL}); then
              echo "${BINARY_DIR}/vmlinux.${1}.4"
            else
              echo "${BINARY_DIR}/vmlinux.${1}.2"
            fi
            ;;
        *)
            echo "Error: Invalid architecture!"
            exit 1
    esac
}

get_binary () {
    if check_arch "${2}"; then
        echo "Error: Invalid architecture!"
        exit 1
    fi

    echo "${BINARY_DIR}/${1}.${2}"
}

get_qemu () {
    if check_arch "${1}"; then
        echo "Error: Invalid architecture!"
        exit 1
    fi

    case "${1}" in
        armel)
            echo "qemu-system-arm"
            ;;
        mipseb)
            echo "qemu-system-mips"
            ;;
        mipsel)
            echo "qemu-system-mipsel"
            ;;
        *)
            echo "Error: Invalid architecture!"
            exit 1
    esac
}

get_qemu_disk () {
    if check_arch "${1}"; then
        echo "Error: Invalid architecture!"
        exit 1
    fi

    case "${1}" in
        armel)
            echo "/dev/vda1"
            ;;
        mipseb)
            echo "/dev/sda1"
            ;;
        mipsel)
            echo "/dev/sda1"
            ;;
        *)
            echo "Error: Invalid architecture!"
            exit 1
    esac
}

get_qemu_machine () {
    if check_arch "${1}"; then
        echo "Error: Invalid architecture!"
        exit 1
    fi

    case "${1}" in
        armel)
            echo "virt"
            ;;
        mipseb)
            echo "malta"
            ;;
        mipsel)
            echo "malta"
            ;;
        *)
            echo "Error: Invalid architecture!"
            exit 1
    esac
}

get_scratch () {
    if check_number "${1}"; then
        echo "Error: Invalid image number!"
        exit 1
    fi

    echo "${SCRATCH_DIR}/${IID}"
}

check_network () {
    sleep 10

    IPS=("${@}")
    DEBUG_MODE=${IPS[-1]}
    unset 'IPS[${#IPS[@]}-1]'

    PING_RESULT=false
    PING_TIME=-1
    WEB_RESULT=false
    WEB_TIME=-1
    RET_IP="None"

    START_TIME=$(date +%s | bc)
    CURRENT_TIME=$(date +%s | bc)
    t_start=$(date +%s.%N)
    while [ ${CURRENT_TIME} -le $[${START_TIME} + ${CHECK_TIMEOUT}] ]
    do
        for IP in "${IPS[@]}"
        do
            if (curl --max-time 2 --output /dev/null --silent http://${IP} || curl --max-time 2 --output /dev/null --silent https://${IP}); then
                t_end=$(date +%s.%N)
                if (! ${WEB_RESULT}); then
                    WEB_TIME=$(echo "$t_end - $t_start" | bc)
                fi
                if (! ${PING_RESULT}); then
                    PING_TIME=${WEB_TIME}
                fi
                PING_RESULT=true
                WEB_RESULT=true
                RET_IP=${IP}
            fi
            if (ping -c 1 ${IP} > /dev/null); then
                t_end=$(date +%s.%N)
                if (! ${PING_RESULT}); then
                    PING_TIME=$(echo "$t_end - $t_start" | bc)
                fi
                PING_RESULT=true
                RET_IP=${IP}
            fi
            sleep 1
            CURRENT_TIME=$(date +%s | bc)
        done

        if (${WEB_RESULT}); then
            break
        fi
    done

    echo "${RET_IP}" "${PING_RESULT}" "${WEB_RESULT}" "${PING_TIME}" "${WEB_TIME}"
}

get_device () {
    echo '/dev/mapper/'`ls -t /dev/mapper | head -1`
}

add_partition () {
    local IMAGE_PATH
    local LOOP_DEV=""
    local DEV_PATH=""
    local WAIT_SECS=30
    local i=0
    local LOOP_BASENAME=""
    local SYS_DEV_FILE=""
    local MAJOR_MINOR=""
    local MAJOR=""
    local MINOR=""
    local DEV_NODE_MM=""
    local LOOP_PART_SYS=""
    local DBG_FILE=""
    local IMAGE_DIRNAME=""
    local IID_GUESS=""

    IMAGE_PATH=$(readlink -f "${1}")
    if [ ! -f "${IMAGE_PATH}" ]; then
        echo "Error: image file not found: ${IMAGE_PATH}" >&2
        return 1
    fi

    IMAGE_DIRNAME=$(dirname "${IMAGE_PATH}")
    IID_GUESS=$(basename "${IMAGE_DIRNAME}" 2>/dev/null || echo "unknown")
    DBG_FILE="${SCRATCH_DIR}/${IID_GUESS}/loop_debug.log"

    # Avoid stale "(deleted)" mappings for the same image path.
    for d in $(losetup -a | awk -F: -v p="${IMAGE_PATH}" '$0 ~ p {print $1}'); do
        losetup -d "${d}" 2>/dev/null || true
    done

    LOOP_DEV=$(losetup --find --show --partscan "${IMAGE_PATH}" 2>/dev/null || true)
    if [ -z "${LOOP_DEV}" ]; then
        echo "Error: losetup failed for ${IMAGE_PATH}" >&2
        return 1
    fi

    # In containers, udev may not create /dev/loopXp1 automatically.
    # Try to force kernel partition scan before waiting.
    partprobe "${LOOP_DEV}" 2>/dev/null || true
    partx -u "${LOOP_DEV}" 2>/dev/null || true

    DEV_PATH="${LOOP_DEV}p1"
    LOOP_BASENAME=$(basename "${LOOP_DEV}")
    LOOP_PART_SYS="/sys/class/block/${LOOP_BASENAME}p1/dev"
    for i in $(seq 1 ${WAIT_SECS}); do
        # Create or refresh missing/stale node from sysfs when partition exists.
        SYS_DEV_FILE="${LOOP_PART_SYS}"
        if [ -f "${SYS_DEV_FILE}" ]; then
            MAJOR_MINOR=$(cat "${SYS_DEV_FILE}" 2>/dev/null || true)
            MAJOR=${MAJOR_MINOR%:*}
            MINOR=${MAJOR_MINOR#*:}
            if [ -n "${MAJOR}" ] && [ -n "${MINOR}" ]; then
                if [ -b "${DEV_PATH}" ]; then
                    DEV_NODE_MM=$(ls -l "${DEV_PATH}" 2>/dev/null | awk '{print $5":"$6}' | tr -d ',')
                    if [ "${DEV_NODE_MM}" != "${MAJOR_MINOR}" ]; then
                        rm -f "${DEV_PATH}" 2>/dev/null || true
                    fi
                fi
                [ -b "${DEV_PATH}" ] || mknod "${DEV_PATH}" b "${MAJOR}" "${MINOR}" 2>/dev/null || true
            fi
        fi

        # The node must not only exist, but also be openable by kernel.
        if [ -b "${DEV_PATH}" ]; then
            if blockdev --getsize64 "${DEV_PATH}" >/dev/null 2>&1; then
                echo "${DEV_PATH}"
                return 0
            fi
        fi
        sleep 1
    done

    # Fallback 1: environments where partition suffix differs
    DEV_PATH=$(ls "${LOOP_DEV}"* 2>/dev/null | grep -E "${LOOP_DEV}(p)?1$" | head -n1 || true)
    if [ -n "${DEV_PATH}" ] && [ -b "${DEV_PATH}" ] && blockdev --getsize64 "${DEV_PATH}" >/dev/null 2>&1; then
        echo "${DEV_PATH}"
        return 0
    fi

    # Fallback 2: if no partition device is exposed, use whole loop device.
    # This is a last resort for constrained container environments.
    if [ -b "${LOOP_DEV}" ] && blockdev --getsize64 "${LOOP_DEV}" >/dev/null 2>&1; then
        echo "${LOOP_DEV}"
        return 0
    fi

    {
        echo "===== add_partition failure ====="
        echo "time: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
        echo "image: ${IMAGE_PATH}"
        echo "loop_dev: ${LOOP_DEV}"
        echo "expected_part: ${LOOP_DEV}p1"
        echo "--- losetup -a ---"
        losetup -a 2>/dev/null || true
        echo "--- ls -l /dev/loop* ---"
        ls -l /dev/loop* 2>/dev/null || true
        echo "--- sysfs block dev map ---"
        for f in /sys/class/block/loop*/dev; do
            [ -f "$f" ] || continue
            echo "$f => $(cat "$f" 2>/dev/null)"
        done
        echo "==============================="
    } >> "${DBG_FILE}" 2>&1 || true

    echo "Error: partition node not ready for ${LOOP_DEV} after ${WAIT_SECS}s" >&2
    return 1
}

del_partition () {
    losetup -d ${1} &> /dev/null || true
    dmsetup remove $(basename ${1}) &>/dev/null || true
    sleep 1
}
